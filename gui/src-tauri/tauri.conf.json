{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Poflow",
  "version": "0.1.0",
  "identifier": "com.poflow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npx vite build",
    "beforeBundleCommand": "cargo build --release -p poflow-daemon 2>&1"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Poflow",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libnotify4", "libsqlite3-0"],
        "files": {
          "usr/bin/poflow-daemon": "../../target/release/poflow-daemon",
          "usr/lib/systemd/user/poflow.service": "../../assets/poflow.service"
        },
        "postInstallScript": "../../packaging/debian/postinst",
        "section": "utils"
      },
      "rpm": {
        "depends": ["libnotify", "sqlite-libs"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
